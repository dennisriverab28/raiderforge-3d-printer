        <mxCell id="h5" value="Homing&#xa;Complete" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#333333;strokeWidth=2;fontSize=17;fontFamily=Arial;" vertex="1" parent="1"><mxGeometry x="810" y="390" width="150" height="85" as="geometry"/></mxCell>
        <mxCell id="h6" value="Homing&#xa;Failed" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#333333;strokeWidth=2;fontSize=17;fontFamily=Arial;fontStyle=1" vertex="1" parent="1"><mxGeometry x="570" y="390" width="150" height="85" as="geometry"/></mxCell>
        <mxCell id="h7" value="Endstops are debounced for 10 ms before the triggered state is accepted." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;fontSize=15;fontFamily=Arial;" vertex="1" parent="1"><mxGeometry x="290" y="550" width="620" height="55" as="geometry"/></mxCell>
