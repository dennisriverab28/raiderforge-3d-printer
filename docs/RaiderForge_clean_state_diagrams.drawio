  <diagram name="8 Homing And Endstops" id="homing_endstops">
    <mxGraphModel dx="1200" dy="700" grid="0" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="675" background="#ffffff" math="0" shadow="0">
      <root>
