        <mxCell id="t6" value="Hotend thermistor uses ADC1 IN9. Bed thermistor uses ADC1 IN11. Mutex protects shared ADC access." style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;strokeWidth=1;fontSize=15;fontFamily=Arial;" vertex="1" parent="1"><mxGeometry x="260" y="120" width="680" height="55" as="geometry"/></mxCell>
