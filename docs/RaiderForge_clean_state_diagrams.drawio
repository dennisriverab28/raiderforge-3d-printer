        <mxCell id="he2" value="endstop hit" style="endArrow=block;endFill=1;html=1;strokeColor=#333333;strokeWidth=2;fontSize=14;fontFamily=Arial;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="h2" target="h3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="he3" value="backed off" style="endArrow=block;endFill=1;html=1;strokeColor=#333333;strokeWidth=2;fontSize=14;fontFamily=Arial;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="h3" target="h4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="he4" value="endstop hit again" style="endArrow=block;endFill=1;html=1;strokeColor=#333333;strokeWidth=2;fontSize=14;fontFamily=Arial;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="h4" target="h5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="he5" value="timeout" style="endArrow=block;endFill=1;html=1;strokeColor=#333333;strokeWidth=2;fontSize=14;fontFamily=Arial;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="h2" target="h6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="he6" value="next axis or idle" style="endArrow=block;endFill=1;html=1;strokeColor=#333333;strokeWidth=2;fontSize=14;fontFamily=Arial;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="h5" target="h1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

