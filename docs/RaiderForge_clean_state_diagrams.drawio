        <mxCell id="1" parent="0"/>
        <mxCell id="h1" value="Homing&#xa;Idle" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;strokeWidth=2;fontSize=17;fontFamily=Arial;" vertex="1" parent="1"><mxGeometry x="80" y="280" width="150" height="85" as="geometry"/></mxCell>
