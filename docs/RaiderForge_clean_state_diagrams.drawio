        <mxCell id="m10" value="Motion Done&#xa;update stored position" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;strokeWidth=2;fontSize=17;fontFamily=Arial;" vertex="1" parent="1"><mxGeometry x="315" y="500" width="175" height="85" as="geometry"/></mxCell>
